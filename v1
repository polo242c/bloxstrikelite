local function ApplyWeaponSkin(weaponModel)
    pcall(function()
        local weaponName = weaponModel.Name
        local isGlove = false; local isKnife = false
        local targetWeaponName = weaponName; local targetSkinName = "Vanilla"
        
        local nLower = string.lower(weaponName)
        if string.find(nLower, "glove") or string.find(nLower, "wraps") or string.find(nLower, "hand") or string.find(nLower, "arm") then
            isGlove = true; targetWeaponName = Config.TargetGlove or "Sports Gloves"; targetSkinName = Config.TargetSkinGlove or "Vanilla"
        end
        for _, knife in ipairs({"CT Knife", "T Knife", "Knife", "BaseKnife", "Melee"}) do
            if nLower == string.lower(knife) or nLower == string.lower(Config.TargetKnife) then
                isKnife = true; targetWeaponName = Config.TargetKnife or "Karambit"; targetSkinName = Config.TargetSkin or "Vanilla"
                break
            end
        end
        
        if not isGlove and not isKnife then
            targetSkinName = Config.ActiveGunSkins[weaponName]
            if not targetSkinName then return end
        end
        if targetSkinName == "Vanilla" or targetSkinName == "Stock" or targetSkinName == "" then return end
        
        local wFolder = skinsFolder:FindFirstChild(targetWeaponName); if not wFolder then return end
        local skinFolder = wFolder:FindFirstChild(targetSkinName); if not skinFolder then return end
        local assetSource = skinFolder:FindFirstChild("Camera") or skinFolder
        local finalSource = assetSource:FindFirstChild("Factory New") or assetSource:FindFirstChild("Minimal Wear") or assetSource:FindFirstChild("Field-Tested") or assetSource:FindFirstChild("Well-Worn") or assetSource:FindFirstChild("Battle-Scarred") or assetSource
        local skinAssets = {}; local fallbackAsset = nil
        for _, obj in pairs(finalSource:GetChildren()) do
            if obj:IsA("SurfaceAppearance") or obj:IsA("Texture") or obj:IsA("Decal") then
                local name = string.lower(obj.Name); skinAssets[name] = obj
                if string.find(name, "body") or string.find(name, "receiver") or string.find(name, "main") then fallbackAsset = obj end
            elseif obj:IsA("MeshPart") then
                skinAssets[string.lower(obj.Name)] = obj
            end
        end
        if not fallbackAsset then for _, obj in pairs(skinAssets) do fallbackAsset = obj; break; end end
        
        local function isArmOrGlove(n) n = string.lower(n); return string.find(n, "glove") or string.find(n, "sleeve") or string.find(n, "arm") or string.find(n, "wrist") or (string.find(n, "hand") and not string.find(n, "handle")) end
        for _, descendant in pairs(weaponModel:GetDescendants()) do 
            if descendant:IsA("BasePart") then
                local descName = string.lower(descendant.Name); local parentName = descendant.Parent and string.lower(descendant.Parent.Name) or ""
                if isGlove then if not isArmOrGlove(descName) and not isArmOrGlove(parentName) then continue end
                else if isArmOrGlove(descName) or isArmOrGlove(parentName) then continue end end
                local targetAsset = skinAssets[descName]
                if not targetAsset then for _, child in pairs(descendant:GetChildren()) do if child:IsA("SurfaceAppearance") then local cName = string.lower(child.Name); if skinAssets[cName] then targetAsset = skinAssets[cName]; break end end end end
                if not targetAsset and descendant:IsA("MeshPart") then targetAsset = fallbackAsset end
                if targetAsset then 
                    for _, old in pairs(descendant:GetChildren()) do if old:IsA("SurfaceAppearance") or old:IsA("Texture") or old:IsA("Decal") then old:Destroy() end end
                    if descendant:IsA("MeshPart") then descendant.TextureID = "" end
                    local specialMesh = descendant:FindFirstChildWhichIsA("SpecialMesh"); if specialMesh then specialMesh.TextureId = "" end
                    if targetAsset:IsA("SurfaceAppearance") then if descendant:IsA("MeshPart") then targetAsset:Clone().Parent = descendant end else targetAsset:Clone().Parent = descendant end
                end 
            end
        end
    end)
end

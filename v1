local function IsTeammate(model)
    if model == LocalPlayer.Character or model.Name == LocalPlayer.Name then return true end
    local player = Players:GetPlayerFromCharacter(model) or Players:FindFirstChild(model.Name)
    if player and LocalPlayer.Team and player.Team == LocalPlayer.Team then return true end
    local myChar = LocalPlayer.Character
    if myChar and myChar.Parent and myChar.Parent:IsA("Folder") and model.Parent == myChar.Parent then return true end
    return false
end

local _visParams = RaycastParams.new()
_visParams.FilterType = Enum.RaycastFilterType.Exclude
local function IsVisibleCheck(targetPart)
    local origin = Camera.CFrame.Position; local direction = targetPart.Position - origin
    local ignoreList = {Camera}
    if LocalPlayer.Character then table.insert(ignoreList, LocalPlayer.Character) end
    local _debris = Workspace:FindFirstChild("Debris"); if _debris then table.insert(ignoreList, _debris) end
    if CharFolder then
        local myTeam = LocalPlayer.Team and LocalPlayer.Team.Name or "None"
        local tFolder = CharFolder:FindFirstChild(myTeam)
        if tFolder then table.insert(ignoreList, tFolder) end
    end
    _visParams.FilterDescendantsInstances = ignoreList

    local attempts = 0
    while attempts < 3 do
        attempts = attempts + 1
        local result = Workspace:Raycast(origin, direction, _visParams)
        if result then
            if result.Instance:IsDescendantOf(targetPart.Parent) then return true
            elseif result.Instance.Transparency >= 0.5 or not result.Instance.CanCollide or string.find(string.lower(result.Instance.Name), "hitbox") or result.Instance.Name == "Glass" then
                table.insert(ignoreList, result.Instance)
                _visParams.FilterDescendantsInstances = ignoreList
            else return false end
        else return true end
    end
    return false
end

local function getTarget(targetFOV)
    local aimPoint = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2); local bestPart, bestDist = nil, targetFOV
    for model, data in pairs(W.PlayerCache) do
        if IsTeammate(model) then continue end
        local part = data[Config.TargetPartMode] or data.Head
        local hum = data.Humanoid
        if hum and hum.Health > 0 and part then
            local pos, onScreen = Camera:WorldToViewportPoint(part.Position)
            if onScreen then
                local d = (Vector2.new(pos.X, pos.Y) - aimPoint).Magnitude
                if d < bestDist then
                    if Config.AimWallCheck and not IsVisibleCheck(part) then continue end
                    bestDist = d; bestPart = part
                end
            end
        end
    end
    return bestPart
end


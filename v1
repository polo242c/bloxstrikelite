local function UpdateESP()
    if not Config.ESP then for m, o in pairs(W.ESP_Objects) do RemoveESP(m) end return end
    local currentModels = {}
    for model, data in pairs(W.PlayerCache) do
        local hum, hrp, head = data.Humanoid, data.Root, data.Head
        if hum and hum.Health > 0 then
            local isFriendly = IsTeammate(model)
            if isFriendly then continue end
            
            local vector, onScreen = Camera:WorldToViewportPoint(hrp.Position); local headVector = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0))
            local drawColor = Color3.fromRGB(255, 50, 50)
            currentModels[model] = true
            if not W.ESP_Objects[model] then
                W.ESP_Objects[model] = { BoxLines = {}, BoxFrame = CreateGuiBox(), Name = CreateGuiText(), HPBg = CreateGuiLine(), HPFill = CreateGuiLine(), Tracer = CreateGuiLine(), SkeletonLines = {} }
                for i = 1, 12 do table.insert(W.ESP_Objects[model].BoxLines, CreateGuiLine()) end; for i = 1, 14 do table.insert(W.ESP_Objects[model].SkeletonLines, CreateGuiLine()) end
            end
            local d = W.ESP_Objects[model]

            if onScreen then
                local boxHeight = math.abs((vector.Y - headVector.Y) * 2.3); local boxWidth = boxHeight / 1.5; local boxPos = Vector2.new(vector.X - boxWidth / 2, vector.Y - boxHeight / 2)
                if Config.Box then d.BoxFrame.Frame.Visible = true; d.BoxFrame.Frame.Position = UDim2.fromOffset(boxPos.X, boxPos.Y); d.BoxFrame.Frame.Size = UDim2.fromOffset(boxWidth, boxHeight); d.BoxFrame.Stroke.Color = drawColor else d.BoxFrame.Frame.Visible = false end
                if Config.Name then d.Name.Visible = true; d.Name.Text = model.Name; d.Name.Position = UDim2.fromOffset(boxPos.X + (boxWidth / 2), boxPos.Y - 15); d.Name.TextColor3 = drawColor else d.Name.Visible = false end
                if Config.HPBar then local hpPercent = math.clamp(hum.Health / math.max(hum.MaxHealth, 1), 0, 1); local barHeight = math.max(1, boxHeight * hpPercent); UpdateGuiLine(d.HPBg, Vector2.new(boxPos.X - 5, boxPos.Y - 1), Vector2.new(boxPos.X - 5, boxPos.Y + boxHeight + 1), 3, Color3.new(0, 0, 0)); UpdateGuiLine(d.HPFill, Vector2.new(boxPos.X - 5, boxPos.Y + boxHeight), Vector2.new(boxPos.X - 5, boxPos.Y + boxHeight - barHeight), 1.5, Color3.new(1 - hpPercent, hpPercent, 0)) else d.HPBg.Visible = false; d.HPFill.Visible = false end
                if Config.Tracers then local startPos = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y); local endPos = Vector2.new(vector.X, vector.Y + (boxHeight / 2)); UpdateGuiLine(d.Tracer, startPos, endPos, 1.5, drawColor) else d.Tracer.Visible = false end

        if Config.ShowFOV then SilentFOV.Visible = true else SilentFOV.Visible = false end
    end
    
    local hue = tick() % 5 / 5
    local pureRgbColor = Color3.fromHSV(hue, 1, 1)
    
    if Config.SpinCrosshair then
        CrossFrame.Visible = true
        CrossFrame.Rotation = (CrossFrame.Rotation + (Config.CrosshairSpeed or 10)) % 360
        l1.BackgroundColor3 = pureRgbColor; l2.BackgroundColor3 = pureRgbColor
    else
        CrossFrame.Visible = false
    end
    
    if c and c:FindFirstChild("Humanoid") then
        local hum = c.Humanoid
        if Config.AutoBhop and UserInputService:IsKeyDown(Enum.KeyCode.Space) then
            hum.Jump = true
        end
    end
    
    local isShooting = UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1)
    if Config.RCS and isShooting then
        local rcsPower = (tonumber(Config.RCS_Strength) or 5) / 20
        if mousemoverel then pcall(function() mousemoverel(0, rcsPower) end) end
    end
    
    local isAiming = UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2)
    if Config.Aimlock and isAiming then
        local targetPart = getTarget(Config.AimFOV)
        if targetPart then 
            local targetPos = targetPart.Position
            local targetRoot = targetPart.Parent:FindFirstChild("HumanoidRootPart")
            if targetRoot and Config.AimPrediction then
                local distToTarget = (targetPos - Camera.CFrame.Position).Magnitude
                targetPos = targetPos + (targetRoot.AssemblyLinearVelocity * (distToTarget / 1500))
            end

            local pos, onScreen = Camera:WorldToViewportPoint(targetPos)
            if onScreen then 
                local aimJitterVal = tonumber(Config.AimJitter) or 10; local jitterAmount = aimJitterVal / 100
                local jX = (math.random() - 0.5) * jitterAmount * 2; local jY = (math.random() - 0.5) * jitterAmount * 2

                local xDiff = (pos.X - centerPoint.X) + jX; local yDiff = (pos.Y - centerPoint.Y) + jY
                local moveX = math.floor(xDiff / Config.AimSmoothness); local moveY = math.floor(yDiff / Config.AimSmoothness)
                
                if Config.AimMethod == "Raw Mouse" then
                    if math.abs(moveX) < 1000 and math.abs(moveY) < 1000 then if mousemoverel then pcall(function() mousemoverel(moveX, moveY) end) end end
                else
                    if math.abs(moveX) < 1000 and math.abs(moveY) < 1000 then if mousemoverel then pcall(function() mousemoverel(moveX, moveY) end) end end
                end
            end
        end
    end
end)

